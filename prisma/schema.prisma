datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model Veterinario {
  id_veterinario Int     @id @default(autoincrement())
  nombre         String  @db.VarChar(100)
  especialidad   String  @db.VarChar(100)
  turnos         Turno[]

  @@map("veterinarios")
}

model Turno {
  id_turno         Int          @id @default(autoincrement())
  cliente_nombre   String       @db.VarChar(100)
  cliente_telefono String       @db.VarChar(20)
  cliente_email    String       @db.VarChar(100)
  mascota_nombre   String       @db.VarChar(100)
  mascota_especie  String       @db.VarChar(50)
  motivo_consulta  String       @db.Text
  fecha_preferida  DateTime     @db.Date
  fecha_confirmada DateTime?    @db.Date
  hora_confirmada  DateTime?    @db.Time(0) // Mapea el formato TIME de MySQL en Prisma
  id_veterinario   Int?
  estado_turno     String       @default("Pendiente") @db.VarChar(30)
  estado_pago      String       @default("No Pago") @db.VarChar(20)
  token_pago       String       @unique @db.VarChar(64)
  veterinario      Veterinario? @relation(fields: [id_veterinario], references: [id_veterinario], onDelete: SetNull, onUpdate: Cascade)

  @@map("turnos")
}